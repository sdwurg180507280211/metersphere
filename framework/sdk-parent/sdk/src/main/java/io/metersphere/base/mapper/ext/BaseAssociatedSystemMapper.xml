<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="io.metersphere.base.mapper.ext.BaseAssociatedSystemMapper">
    <resultMap id="BaseResultMap" type="io.metersphere.base.domain.AssociatedSystem">
        <id column="id" jdbcType="VARCHAR" property="id" />
        <result column="workspace_id" jdbcType="VARCHAR" property="workspaceId" />
        <result column="name" jdbcType="VARCHAR" property="name" />
        <result column="description" jdbcType="VARCHAR" property="description" />
        <result column="create_time" jdbcType="BIGINT" property="createTime" />
        <result column="update_time" jdbcType="BIGINT" property="updateTime" />
    </resultMap>
    <sql id="Base_Column_List">
        id, workspace_id, `name`, description, create_time, update_time
    </sql>
    <select id="getAssociatedSystemWithWorkspace" resultMap="BaseResultMap">
        SELECT u.id, u.name, u.description,
        u.workspace_id,  u.create_time, u.update_time
        FROM associated_system u
        <where>
            <if test="associatedSystemRequest.id != null">
                AND u.id LIKE CONCAT('%', #{associatedSystemRequest.id},'%')
            </if>
            <if test="associatedSystemRequest.name != null">
                AND u.name LIKE CONCAT('%', #{associatedSystemRequest.name},'%')

            </if>
            <if test="associatedSystemRequest.description != null">
                AND u.description LIKE CONCAT('%', #{associatedSystemRequest.description},'%')
            </if>
        </where>
        <if test="associatedSystemRequest.orders != null and associatedSystemRequest.orders.size() > 0">
            ORDER BY
            <foreach collection="associatedSystemRequest.orders" separator="," item="order">
                ${order.name} ${order.type}
            </foreach>
        </if>
    </select>

    <select id="getAssociatedSystemWithWorkspaceId" resultMap="BaseResultMap">
            SELECT DISTINCT *
            from associated_system where workspace_id=#{workspaceId} order by create_time desc
        </select>

</mapper>
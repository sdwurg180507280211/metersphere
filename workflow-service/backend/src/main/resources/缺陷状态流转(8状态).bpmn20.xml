<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" targetNamespace="http://metersphere.io/bpmn">
  <bpmn:process id="issue_status_flow" name="缺陷状态流转(8状态)" isExecutable="true">
    <bpmn:startEvent id="start" name="开始">
      <bpmn:outgoing>flow_start_to_new</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="task_new" name="新建(new)" camunda:assignee="${processorId}">
      <bpmn:incoming>flow_start_to_new</bpmn:incoming>
      <bpmn:outgoing>flow_new_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_after_new">
      <bpmn:incoming>flow_new_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_new_to_accepted</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_accept" name="已接收(accepted)" camunda:assignee="${processorId}">
      <bpmn:incoming>flow_new_to_accepted</bpmn:incoming>
      <bpmn:incoming>flow_reopened_to_accept</bpmn:incoming>
      <bpmn:outgoing>flow_accept_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_after_accept">
      <bpmn:incoming>flow_accept_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_accept_to_resolved</bpmn:outgoing>
      <bpmn:outgoing>flow_accept_to_invalid</bpmn:outgoing>
      <bpmn:outgoing>flow_accept_to_on_hold</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_resolved" name="已解决(resolved)" camunda:assignee="${creatorId}">
      <bpmn:incoming>flow_accept_to_resolved</bpmn:incoming>
      <bpmn:incoming>flow_on_hold_to_resolved</bpmn:incoming>
      <bpmn:outgoing>flow_resolved_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="task_invalid" name="无效(invalid)" camunda:assignee="${creatorId}">
      <bpmn:incoming>flow_accept_to_invalid</bpmn:incoming>
      <bpmn:outgoing>flow_invalid_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_after_invalid">
      <bpmn:incoming>flow_invalid_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_invalid_to_cancelled</bpmn:outgoing>
      <bpmn:outgoing>flow_invalid_to_reopened</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_on_hold" name="挂起(on_hold)" camunda:assignee="${processorId}">
      <bpmn:incoming>flow_accept_to_on_hold</bpmn:incoming>
      <bpmn:outgoing>flow_on_hold_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_after_on_hold">
      <bpmn:incoming>flow_on_hold_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_on_hold_to_resolved</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_reopened" name="重新打开(reopened)" camunda:assignee="${processorId}">
      <bpmn:incoming>flow_invalid_to_reopened</bpmn:incoming>
      <bpmn:incoming>flow_resolved_to_reopened</bpmn:incoming>
      <bpmn:outgoing>flow_reopened_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_after_reopened">
      <bpmn:incoming>flow_reopened_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_reopened_to_accept</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_cancelled" name="已取消(cancelled)">
      <bpmn:incoming>flow_invalid_to_cancelled</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_new" sourceRef="start" targetRef="task_new" />
    <bpmn:sequenceFlow id="flow_new_to_gw" sourceRef="task_new" targetRef="gw_after_new" />
    <bpmn:sequenceFlow id="flow_new_to_accepted" sourceRef="gw_after_new" targetRef="task_accept">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'accepted'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_accept_to_gw" sourceRef="task_accept" targetRef="gw_after_accept" />
    <bpmn:sequenceFlow id="flow_accept_to_resolved" sourceRef="gw_after_accept" targetRef="task_resolved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'resolved'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_accept_to_invalid" sourceRef="gw_after_accept" targetRef="task_invalid">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'invalid'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_accept_to_on_hold" sourceRef="gw_after_accept" targetRef="task_on_hold">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'on_hold'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_resolved_to_gw" sourceRef="task_resolved" targetRef="gw_after_resolved" />
    <bpmn:sequenceFlow id="flow_resolved_to_closed" sourceRef="gw_after_resolved" targetRef="end_closed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'closed'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_resolved_to_reopened" sourceRef="gw_after_resolved" targetRef="task_reopened">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'reopened'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_invalid_to_gw" sourceRef="task_invalid" targetRef="gw_after_invalid" />
    <bpmn:sequenceFlow id="flow_invalid_to_cancelled" sourceRef="gw_after_invalid" targetRef="end_cancelled">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'cancelled'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_invalid_to_reopened" sourceRef="gw_after_invalid" targetRef="task_reopened">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'reopened'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_on_hold_to_gw" sourceRef="task_on_hold" targetRef="gw_after_on_hold" />
    <bpmn:sequenceFlow id="flow_on_hold_to_resolved" sourceRef="gw_after_on_hold" targetRef="task_resolved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'resolved'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_reopened_to_gw" sourceRef="task_reopened" targetRef="gw_after_reopened" />
    <bpmn:sequenceFlow id="flow_reopened_to_accept" sourceRef="gw_after_reopened" targetRef="task_accept">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${toStatus == 'accepted'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="end_closed" name="关闭(closed)">
      <bpmn:incoming>flow_resolved_to_closed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="gw_after_resolved">
      <bpmn:incoming>flow_resolved_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_resolved_to_reopened</bpmn:outgoing>
      <bpmn:outgoing>flow_resolved_to_closed</bpmn:outgoing>
    </bpmn:exclusiveGateway>
  </bpmn:process>

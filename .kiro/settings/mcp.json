{
  "mcpServers": {
    "chrome-devtools": {
      "command": "/Users/zhaozhiwei/.nvm/versions/node/v20.19.6/bin/npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--channel=stable"
      ],
      "env": {
        "PATH": "/Users/zhaozhiwei/.nvm/versions/node/v20.19.6/bin:/usr/local/bin:/usr/bin:/bin",
        "NODE_PATH": "/Users/zhaozhiwei/.nvm/versions/node/v20.19.6/lib/node_modules"
      },
      "autoApprove": [
        // 页面导航与控制
        "navigate_page",
        "reload_page",
        "go_back",
        "go_forward",
        // 截图与快照
        "take_screenshot",
        "take_snapshot", // 获取 DOM + 样式快照（结构化数据）
        // 控制台日志
        "list_console_messages",
        "clear_console_messages",
        // 网络监控
        "list_network_requests",
        "get_network_request_details",
        // 元素交互
        "click",
        "hover",
        "type_text",
        "press_key",
        "scroll_to",
        // DOM 操作
        "get_element_html",
        "get_element_text",
        "get_computed_style",
        "find_elements",
        // 页面信息
        "get_page_content",
        "get_page_title",
        "get_page_url",
        // 脚本执行
        "evaluate_script",
        "call_function",
        // 性能与审计
        "start_performance_recording",
        "stop_performance_recording",
        "run_lighthouse_audit",
        // 存储与 Cookie
        "get_cookies",
        "set_cookie",

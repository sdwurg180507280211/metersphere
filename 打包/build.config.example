# MeterSphere 构建配置文件
# 将此文件重命名为 .build.config 并放在脚本同级目录

# 项目路径（留空则自动探测）
PROJECT_PATH=

# 镜像仓库地址
REGISTRY=registry.fit2cloud.com/north

# 打包输出路径
PACKAGE_PATH=$HOME/Desktop/metersphere-$(date +%y%m%d).tar

# 跳过 Maven 依赖安装（首次构建设为 false）
SKIP_INIT=false

# 并行构建（可提高构建速度，但需要更多内存）
PARALLEL_BUILD=false

# 并行任务数（建议不超过 CPU 核心数）
MAX_JOBS=4

# 只构建镜像不导出 tar（测试时可设为 true）
BUILD_ONLY=false

# 不使用 Docker 构建缓存
NO_CACHE=false

# Maven 额外选项
MAVEN_OPTS=

# ============================================================================
# 每服务独立镜像版本
# 通过 SERVICE_VERSION_<MOD> 环境变量设置，MOD 名大写，- 替换为 _
# 通常由控制面板自动传入，也可手动设置
# ============================================================================
# SERVICE_VERSION_EUREKA=v2.10.26.01-lts
# SERVICE_VERSION_GATEWAY=v2.10.26.01-lts
# SERVICE_VERSION_SYSTEM_SETTING=v2.10.26.01-lts
# SERVICE_VERSION_PROJECT_MANAGEMENT=v2.10.26.01-lts
# SERVICE_VERSION_PERFORMANCE_TEST=v2.10.26.01-lts
# SERVICE_VERSION_API_TEST=v2.10.26.01-lts
# SERVICE_VERSION_TEST_TRACK=v2.10.26.01-lts
# SERVICE_VERSION_REPORT_STAT=v2.10.26.01-lts
# SERVICE_VERSION_WORKSTATION=v2.10.26.01-lts
